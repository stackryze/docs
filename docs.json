        "tab": "Guides",
        "icon": "compass",
        "pages": [
          {
            "group": "Integration Guides",
            "pages": [
              "guides/add-a-custom-domain",
              "guides/point-domain-to-stackryze",
              "guides/transfer-domain",
              "guides/configure-dns-records",
              "guides/enable-dnssec",
              "guides/dynamic-dns",
              "guides/api-quickstart",
              "guides/webhooks"
