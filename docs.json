{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stackryze",
  "description": "Affordable software for the modern web — domains, DNS, and beyond.",
  "colors": {
    "primary": "#4FBE7A",
    "light": "#7DD9A1",
    "dark": "#2E7D4F"
